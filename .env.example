# ─────────────────────────────────────────────────────────────
# Database — Neon PostgreSQL
# ─────────────────────────────────────────────────────────────
# 1. Załóż projekt na https://neon.tech
# 2. Dashboard → Connection Details → skopiuj "Connection string" (Pooled).
# 3. Upewnij się, że na końcu jest ?sslmode=require — Neon wymaga SSL.
# Wskazówka: do Prisma migrate użyj połączenia bez poolera (Direct),
# a do runtime'u połączenia z poolerem (-pooler w hoście).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require"

# ─────────────────────────────────────────────────────────────
# NextAuth (Auth.js v5)
# ─────────────────────────────────────────────────────────────
# Sekret do podpisywania/szyfrowania tokenów sesji (JWT).
# Wygeneruj losowy ciąg jedną z komend:
#   npx auth secret
#   openssl rand -base64 32
# Nigdy nie commituj prawdziwej wartości do repo.
NEXTAUTH_SECRET="wygeneruj-mnie-openssl-rand-base64-32"

# Publiczny URL aplikacji — używany przez callbacki OAuth.
# Lokalnie: http://localhost:3000
# Produkcja (Vercel): https://twoja-domena.vercel.app (lub własna domena)
NEXTAUTH_URL="http://localhost:3000"
